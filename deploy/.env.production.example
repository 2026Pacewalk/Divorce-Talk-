# Production .env for DivorceTalk.in. Copy to /var/www/divorcetalk/.env and
# fill in the blanks. Keep this file out of git (it's already in .gitignore).

# ── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000

APP_ID=divorcetalk-prod
# A long random secret used to sign local-auth JWTs.
# Generate one:  openssl rand -base64 64
APP_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ── Database ─────────────────────────────────────────────────
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://divorcetalk:CHANGE_ME@127.0.0.1:3306/divorcetalk

# ── Admin bootstrap ──────────────────────────────────────────
# Reserved for future use. Leave empty.
OWNER_UNION_ID=
