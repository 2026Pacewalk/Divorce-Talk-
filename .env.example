# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for local-auth JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=           # Reserved — first user with this id is promoted to admin on signup
